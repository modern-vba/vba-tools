{
  "name": "vba-tools",
  "displayName": "VBA Tools",
  "description": "Visual Studio Code tooling for VBA projects.",
  "version": "0.0.1",
  "publisher": "tkmr-akhs",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:vba",
    "onCommand:vbaTools.doctor"
  ],
  "main": "./client/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "vba",
        "aliases": [
          "VBA",
          "Visual Basic for Applications"
        ],
        "extensions": [
          ".bas",
          ".cls",
          ".frm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vba",
        "scopeName": "source.vba",
        "path": "./syntaxes/vba.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "vbaTools.doctor",
        "title": "VBA Tools: Doctor"
      }
    ],
    "configuration": {
      "title": "VBA Tools",
      "properties": {
        "vbaLanguageServer.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Controls LSP trace output for the VBA language server."
        },
        "vbaLanguageServer.mainHostApplication": {
          "scope": "resource",
          "type": "string",
          "enum": [
            "excel",
            "word",
            "powerpoint",
            "access"
          ],
          "default": "excel",
          "description": "Controls the primary Office host application for unqualified VBA host object model references."
        },
        "vbaLanguageServer.additionalHostApplications": {
          "scope": "resource",
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "excel",
              "word",
              "powerpoint",
              "access"
            ]
          },
          "default": [],
          "description": "Controls additional Office host applications enabled alongside the main VBA host application."
        },
        "vbaTools.devtool.path": {
          "scope": "machine-overridable",
          "type": "string",
          "default": "",
          "description": "Overrides the bundled vba-devtool executable path for development or diagnostics."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -b",
    "test": "npm run test:extension && npm run test:devtool",
    "test:extension": "npm run compile && node server/out/testRunner.js && node client/out/testRunner.js",
    "test:devtool": "dotnet test tools/vba-devtool/tests/VbaDevTool.Tests/VbaDevTool.Tests.csproj -m:1 -p:UseSharedCompilation=false",
    "build:devtool": "dotnet build tools/vba-devtool/src/VbaDevTool.Cli/VbaDevTool.Cli.csproj -m:1 -p:UseSharedCompilation=false",
    "watch": "tsc -b -w",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.9.0"
  }
}
